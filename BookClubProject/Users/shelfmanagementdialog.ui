     <property name="styleSheet">
      <string notr="true">QListWidget#shelfList {
    font-size: 18px;
    border: 3px solid black;
    border-radius: 12px;
    background-color: white;
}

QListWidget#shelfList::item {
    padding: 12px;
    margin: 2px;
    border-radius: 8px;
    color: rgb(0, 0, 0);
}

QListWidget#shelfList::item:selected {
    background-color: rgb(70, 130, 180);
    color: white;
}

QListWidget#shelfList::item:hover:!selected {
    background-color: rgb(230, 240, 250);
}</string>
