    <property name="styleSheet">
     <string notr="true">QListWidget#notificationList {
    background-color: black;
    border: 3px solid black;
    border-radius: 12px;
    outline: none;
    font-size: 17px;
}

QListWidget#notificationList::item {
    padding: 10px;
    border-bottom: 1px solid rgb(233, 236, 239);
    min-height: 60px;
}

QListWidget#notificationList::item:selected {
    background-color: rgb(227, 242, 253);
    border-left: 3px solid black;
}

QListWidget#notificationList::item:hover:!selected {
    background-color: rgb(0, 0, 0);
}

QListWidget#notificationList::item:alternate {
    background-color: rgb(0, 0, 0);
}</string>
