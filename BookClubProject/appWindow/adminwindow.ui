  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-image: url(:/images/white.png);
    background-position: center;
}
QPushButton {
    background-color: #2c3e50;
    color: white;
    border: 3px solid black;
    border-radius: 12px;
    font-family: &quot;Script MT Bold&quot;;
    font-size: 16px;
    padding: 8px 20px;
    min-height: 30px;
}
QPushButton:hover {
    background-color: #34495e;
}
QPushButton#btnBack {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 211px;
    height: 71px;
    background-color: #e74c3c;
    font-size: 18px;
}
QPushButton#btnBack:hover {
    background-color: #c0392b;
}
QTabWidget::pane {
    border: 3px solid black;
    border-radius: 12px;
    background-color: rgba(255, 255, 255, 0.95);
    margin-top: -1px;
}
QTabBar::tab {
    background-color: #ecf0f1;
    border: 2px solid #bdc3c7;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    padding: 10px 25px;
    margin-right: 2px;
    font-family: &quot;Script MT Bold&quot;;
    font-size: 16px;
    color: #2c3e50;
}
QTabBar::tab:selected {
    background-color: #3498db;
    color: white;
    border: 2px solid #2980b9;
}
QTableWidget {
    border: 3px solid black;
    border-radius: 12px;
    gridline-color: #bdc3c7;
    background-color: white;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
}
QTableWidget::item {
    padding: 8px;
}
QHeaderView::section {
    background-color: #3498db;
    color: white;
    padding: 10px;
    border: 2px solid #2980b9;
    font-family: &quot;Script MT Bold&quot;;
    font-size: 14px;
}
QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox {
    border: 3px solid black;
    border-radius: 12px;
    padding: 8px;
    font-size: 14px;
    background-color: white;
}
QLabel#lblTitle {
    font-family: &quot;Script MT Bold&quot;;
    font-size: 40px;
    color: #2c3e50;
}
QGroupBox {
    border: 3px solid black;
    border-radius: 12px;
    margin-top: 15px;
    padding-top: 20px;
    font-family: &quot;Script MT Bold&quot;;
    font-size: 18px;
    color: #2c3e50;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 20px;
    padding: 0 10px;
}
QTextEdit {
    border: 3px solid black;
    border-radius: 12px;
    background-color: white;
}</string>
